{
  "version": "v1",
  "score_scale": {
    "min": 1,
    "max": 10
  },
  "global_rules": {
    "higher_score_means_better": true,
    "insufficient_evidence_status": "insufficient_evidence"
  },
  "report_rules": {
    "default_risk_level_mapping": {
      "high": "<4",
      "medium": ">=4 and <7",
      "low": ">=7"
    }
  }
}
